# =============================================================================
# PHU - Sistem Manajemen Penyelenggara Perjalanan Ibadah Umrah/Haji (NTB)
# =============================================================================
# Salin file ini ke .env lalu jalankan: php artisan key:generate
# Panduan lengkap: SETUP.md
# Setup cepat: php artisan migrate && php artisan storage:link
# Login default (setelah migrate): admin@phu.com / admin123
# =============================================================================

# --- Aplikasi ---
APP_NAME=PHU
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
ASSET_URL=

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=phu
DB_USERNAME=root
DB_PASSWORD=

# --- Session & Autentikasi ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BCRYPT_ROUNDS=10

# Domain SPA untuk Laravel Sanctum (pisahkan dengan koma)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

# --- Cache & Queue ---
# Production modul V2: CACHE_DRIVER=redis (lihat SETUP.md)
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# --- Filesystem ---
# Upload: BAP PDF, sertifikat, dokumen jamaah, pengaduan, pengunduran
FILESYSTEM_DISK=local

# --- Email (opsional — untuk notifikasi reset password) ---
# Gunakan MAIL_MAILER=log untuk development
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@phu.local
MAIL_FROM_NAME="${APP_NAME}"

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Broadcasting (tidak digunakan, biarkan null) ---
BROADCAST_DRIVER=null

# =============================================================================
# OPSIONAL — hanya diisi jika menggunakan layanan berikut
# =============================================================================

# Redis (jika CACHE_DRIVER=redis atau SESSION_DRIVER=redis)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# AWS S3 (jika FILESYSTEM_DISK=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Mailgun / Postmark (jika MAIL_MAILER=mailgun atau postmark)
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=
# MAILGUN_ENDPOINT=api.mailgun.net
# POSTMARK_TOKEN=
